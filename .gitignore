# Rust build artifacts (also covers the release dist staging in target/dist).
/target

# rustfmt backups
**/*.rs.bk

# insta: pending snapshots awaiting review (accepted ones live in *.snap).
**/*.snap.new
**/*.pending-snap

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Note: Cargo.lock IS committed on purpose — this workspace ships a binary
# (kingsmerchant), so a locked, reproducible dependency set is what we want.

# Local release staging (packaged tarballs)
dist/

# Local-only release helper (never upload)
/scripts/deploy.sh
